{#
    Restaurant Product Card
    كرت المنتج للمطاعم - سُفرة (Sufrah) Theme

    Parameters:
    - product: Product object
    - layout: 'grid' | 'list' | 'menu'
    - show_description: boolean
    - description_length: number
    - image_ratio: '1:1' | '4:3' | '16:9'
    - show_tags: boolean
#}

{% set layout = layout ?? 'grid' %}
{% set showDesc = show_description ?? true %}
{% set descLength = description_length ?? 100 %}
{% set imageRatio = image_ratio ?? '1:1' %}
{% set showTags = show_tags ?? true %}

{% set imageRatioClass = 'product-card-ratio-' ~ (imageRatio | replace({':': '-'})) %}

<article class="product-card product-card-{{ layout }} {{ imageRatioClass }}"
         data-product-id="{{ product.id }}"
         itemscope
         itemtype="https://schema.org/Product">

    {# صورة المنتج #}
    <div class="product-card-image-wrapper">
        <a href="{{ product.url }}" class="product-card-image-link" aria-label="{{ product.name }}">
            {% if product.image and not (product.image | is_placeholder) %}
                <img src="{{ product.image }}"
                     alt="{{ product.name }}"
                     class="product-card-image"
                     loading="lazy"
                     itemprop="image">
            {% else %}
                {# Placeholder image #}
                <div class="product-card-placeholder">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <circle cx="8.5" cy="8.5" r="1.5" />
                        <path d="M21 15l-5-5L5 21" />
                    </svg>
                </div>
            {% endif %}
        </a>

        {# شارة "نفذت الكمية" #}
        {% if not product.in_stock %}
            <div class="product-card-badge product-card-badge-out-of-stock">
                {% if lang.code == 'ar' %}
                    نفذت الكمية
                {% else %}
                    Out of Stock
                {% endif %}
            </div>
        {% endif %}

        {# شارة "تخفيض" #}
        {% if product.sale_price and product.sale_price < product.price %}
            <div class="product-card-badge product-card-badge-sale">
                {% set discount = ((product.price - product.sale_price) / product.price * 100) | round %}
                -{{ discount }}%
            </div>
        {% endif %}

        {# أيقونة المفضلة #}
        <button class="product-card-wishlist-btn"
                onclick="salla.wishlist.toggle({{ product.id }})"
                aria-label="{% if lang.code == 'ar' %}أضف للمفضلة{% else %}Add to Wishlist{% endif %}"
                data-id="{{ product.id }}">
            <svg class="product-card-wishlist-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
        </button>
    </div>

    {# محتوى المنتج #}
    <div class="product-card-content">
        {# الوسوم (Tags) #}
        {% if showTags and product.tags is defined and product.tags|length > 0 %}
            <div class="product-card-tags">
                {% for tag in product.tags | slice(0, 2) %}
                    <span class="product-card-tag">{{ tag.name }}</span>
                {% endfor %}
            </div>
        {% endif %}

        {# اسم المنتج #}
        <h3 class="product-card-title" itemprop="name">
            <a href="{{ product.url }}" class="product-card-title-link">
                {{ product.name }}
            </a>
        </h3>

        {# الوصف (اختياري) #}
        {% if showDesc and product.description %}
            <p class="product-card-description">
                {% if product.description|length > descLength %}
                    {{ product.description|slice(0, descLength) }}...
                {% else %}
                    {{ product.description }}
                {% endif %}
            </p>
        {% endif %}

        {# التقييم (Rating) #}
        {% if product.rating and product.rating > 0 %}
            <div class="product-card-rating" itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
                <div class="product-card-stars">
                    {% for i in 1..5 %}
                        <svg class="product-card-star {{ i <= product.rating ? 'star-filled' : 'star-empty' }}"
                             width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                    {% endfor %}
                </div>
                <span class="product-card-rating-text">
                    <span itemprop="ratingValue">{{ product.rating }}</span>
                    {% if product.rating_count %}
                        <span class="product-card-rating-count">({{ product.rating_count }})</span>
                    {% endif %}
                </span>
            </div>
        {% endif %}

        {# السعر والزر #}
        <div class="product-card-footer">
            <div class="product-card-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                {% if product.sale_price and product.sale_price < product.price %}
                    <span class="product-card-price-original">{{ product.price | currency }}</span>
                    <span class="product-card-price-sale" itemprop="price" content="{{ product.sale_price }}">
                        {{ product.sale_price | currency }}
                    </span>
                {% else %}
                    <span class="product-card-price-current" itemprop="price" content="{{ product.price }}">
                        {{ product.price | currency }}
                    </span>
                {% endif %}
                <meta itemprop="priceCurrency" content="{{ store.currency }}" />
                <link itemprop="availability" href="https://schema.org/{{ product.in_stock ? 'InStock' : 'OutOfStock' }}" />
            </div>

            {# زر الإضافة للسلة #}
            {% if product.in_stock %}
                <button class="product-card-add-btn"
                        onclick="salla.cart.addItem({{ product.id }}, 1)"
                        aria-label="{% if lang.code == 'ar' %}أضف للسلة{% else %}Add to Cart{% endif %}">
                    <svg class="product-card-add-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                    <span class="product-card-add-text">
                        {% if lang.code == 'ar' %}
                            أضف
                        {% else %}
                            Add
                        {% endif %}
                    </span>
                </button>
            {% else %}
                <button class="product-card-add-btn product-card-add-btn-disabled" disabled>
                    {% if lang.code == 'ar' %}
                        نفذت الكمية
                    {% else %}
                        Out of Stock
                    {% endif %}
                </button>
            {% endif %}
        </div>
    </div>
</article>
